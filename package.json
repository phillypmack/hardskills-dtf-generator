{
  "name": "hardskills-adesivos-dtf-uv",
  "version": "1.1.0",
  "description": "Gerador profissional de adesivos DTF UV para tecnologias e linguagens de programacao",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run build:css && vite build",
    "build:css": "npx tailwindcss -i css/input.css -o css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i css/input.css -o css/tailwind.css --watch",
    "preview": "vite preview",
    "update-svg-list": "node generate-svg-list.cjs"
  },
  "keywords": [
    "adesivos",
    "dtf",
    "uv",
    "svg",
    "stickers",
    "programming",
    "devicon",
    "tech-stickers"
  ],
  "author": "Felipe",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
